cypress.json
cypress.env.json

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.test

# MacOS files
.DS_Store

# VSCode files
.vscode/

# IDE files
.idea/

